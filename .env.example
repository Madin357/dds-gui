# Environment: "development" or "production"
ENVIRONMENT=development

# Security — generate for production: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-key-change-in-production

# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///platform.db
DATABASE_URL_SYNC=sqlite:///platform.db
# DATABASE_URL=postgresql+asyncpg://dds:dds_dev_password@localhost:5432/eduscope
# DATABASE_URL_SYNC=postgresql://dds:dds_dev_password@localhost:5432/eduscope

# Redis — required for Celery background tasks
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Mock data sources path
MOCK_SOURCES_PATH=../mock-sources

# Anthropic API key (for AI recommendations)
ANTHROPIC_API_KEY=your-key-here
